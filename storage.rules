rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Each creator uploads into their own folder: media/{uid}/filename
    match /media/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Published universes' media needs to be viewable by anonymous
    // recipients. Files referenced by a published universe are copied (or
    // simply made readable) under public/{universeId}/... — simplest path:
    // mark files public at upload time for content attached to a published
    // universe, or serve via a signed URL from a Cloud Function if you want
    // tighter control later.
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
