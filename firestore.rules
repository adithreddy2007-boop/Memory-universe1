rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each creator can only read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /universes/{universeId} {
      // Owner has full access. Anyone (including signed-out recipients) may
      // read a universe once it's published — this is what makes the
      // shared link work with no login.
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;

      match /memoryStars/{starId} {
        allow read: if get(/databases/$(database)/documents/universes/$(universeId)).data.status == 'published'
                    || (request.auth != null &&
                        request.auth.uid == get(/databases/$(database)/documents/universes/$(universeId)).data.ownerId);
        allow write: if request.auth != null &&
                     request.auth.uid == get(/databases/$(database)/documents/universes/$(universeId)).data.ownerId;
      }
    }

    // Creator's private media library.
    match /media/{mediaId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }
  }
}
